// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Affiliate {
  id                   String       @id @default(uuid())
  shop                 String
  affiliateIdentifier  String       // El ID único ej: TIENDASMART
  commissionPercentage Float        // Porcentaje a pagar al afiliado
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  conversions          Conversion[]

  @@unique([shop, affiliateIdentifier]) // Un identificador debe ser único por tienda
}

model Conversion {
  id                  String    @id @default(uuid())
  shop                String
  affiliateId         String
  orderId             String    // ID de la orden en Shopify (GID)
  orderTotal          Float
  commissionApp       Float     // El 5% cobrado por uso
  commissionAffiliate Float     // Lo que gana el afiliado
  usageRecordId       String?   // ID del cobro en Shopify (para trazabilidad)
  createdAt           DateTime  @default(now())

  affiliate           Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
}
